# =============================================================================
# .gitignore — Dotfiles repo gitignore
# =============================================================================

# ── Machine-specific files (NEVER commit these) ───────────────────────────────
.local/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.Spotlight-V100
.Trashes

# ── Secrets & credentials ─────────────────────────────────────────────────────
*.pem
*.key
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
.env
.env.*
!.env.example
secrets/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Editor ───────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
