#!/usr/bin/env bash
# =============================================================================
# dotcheck — Audit your dotfiles setup and show what's active or missing
# Run this after installation or any time you want to verify your setup.
# Usage: dotcheck
# =============================================================================

set -euo pipefail

GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
PASS=0; WARN=0; FAIL=0

ok()   { echo -e "  ${GREEN}✓${RESET}  $*"; PASS=$((PASS + 1)); }
warn() { echo -e "  ${YELLOW}⚠${RESET}  $*"; WARN=$((WARN + 1)); }
fail() { echo -e "  ${RED}✗${RESET}  $*"; FAIL=$((FAIL + 1)); }
section() { echo -e "\n${BOLD}${BLUE}── $* ──────────────────────────────────────${RESET}"; }

echo -e "\n${BOLD}dotcheck — Setup audit${RESET} ${DIM}(~/.dotfiles)${RESET}\n"

# ── Machine Identity ──────────────────────────────────────────────────────────
section "Machine Identity"

if [[ -f "$DOTFILES_DIR/.local/machine.sh" ]]; then
  source "$DOTFILES_DIR/.local/machine.sh"
  ok "machine.sh found — role: ${MACHINE_ROLE:-unknown}, host: ${MACHINE_NAME:-unknown}"
else
  fail "machine.sh missing — run bootstrap.sh to generate it"
fi

# ── Homebrew ──────────────────────────────────────────────────────────────────
section "Homebrew"

if command -v brew &>/dev/null; then
  BREW_VER=$(brew --version | head -1)
  ok "Homebrew installed — $BREW_VER"

  OUTDATED=$(brew outdated --quiet 2>/dev/null | wc -l | tr -d ' ')
  [[ "$OUTDATED" -gt 0 ]] \
    && warn "$OUTDATED package(s) outdated — run: brewup" \
    || ok "All packages up to date"
else
  fail "Homebrew not installed — run bootstrap.sh"
fi

# ── Shell ─────────────────────────────────────────────────────────────────────
section "Shell"

BREW_PREFIX="${BREW_PREFIX:-/opt/homebrew}"
ZSH_PATH="$BREW_PREFIX/bin/zsh"

[[ "$SHELL" == "$ZSH_PATH" ]] \
  && ok "Default shell is Homebrew Zsh ($ZSH_PATH)" \
  || warn "Default shell is $SHELL — expected $ZSH_PATH. Run: chsh -s $ZSH_PATH"

[[ -d "$HOME/.oh-my-zsh" ]] \
  && ok "Oh My Zsh installed" \
  || fail "Oh My Zsh missing — run bootstrap.sh"

for plugin in zsh-autosuggestions zsh-syntax-highlighting you-should-use; do
  [[ -d "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/$plugin" ]] \
    && ok "Plugin: $plugin" \
    || warn "Plugin missing: $plugin"
done

# ── Symlinks ──────────────────────────────────────────────────────────────────
section "Symlinks"

check_link() {
  local label="$1" dest="$2" expected_src="$3"
  if [[ -L "$dest" ]]; then
    local actual_src
    actual_src=$(readlink "$dest")
    [[ "$actual_src" == "$expected_src" ]] \
      && ok "$label → $dest" \
      || warn "$label points to wrong target: $actual_src"
  elif [[ -f "$dest" ]]; then
    warn "$label is a real file, not a symlink — run: bash $DOTFILES_DIR/scripts/symlink.sh"
  else
    fail "$label not linked — run: bash $DOTFILES_DIR/scripts/symlink.sh"
  fi
}

check_link ".zshrc"          "$HOME/.zshrc"                            "$DOTFILES_DIR/zsh/.zshrc"
check_link ".zshenv"         "$HOME/.zshenv"                           "$DOTFILES_DIR/zsh/.zshenv"
check_link ".gitconfig"      "$HOME/.gitconfig"                        "$DOTFILES_DIR/git/.gitconfig"
check_link ".gitignore_global" "$HOME/.gitignore_global"               "$DOTFILES_DIR/git/.gitignore_global"
check_link "ssh/config"      "$HOME/.ssh/config"                       "$DOTFILES_DIR/ssh/config"
check_link "CLAUDE.md"       "$HOME/.claude/CLAUDE.md"                 "$DOTFILES_DIR/claude/CLAUDE.md"
check_link "claude settings" "$HOME/.claude/settings.json"             "$DOTFILES_DIR/claude/settings.json"

VSCODE_DIR="$HOME/Library/Application Support/Code/User"
check_link "vscode settings"    "$VSCODE_DIR/settings.json"    "$DOTFILES_DIR/vscode/settings.json"
check_link "vscode keybindings" "$VSCODE_DIR/keybindings.json" "$DOTFILES_DIR/vscode/keybindings.json"

# ── Git Identity ──────────────────────────────────────────────────────────────
section "Git Identity"

GIT_NAME=$(git config --global user.name 2>/dev/null || echo "")
GIT_EMAIL=$(git config --global user.email 2>/dev/null || echo "")

if [[ -n "$GIT_NAME" && -n "$GIT_EMAIL" ]]; then
  ok "Global git identity: $GIT_NAME <$GIT_EMAIL>"
else
  warn "No global git identity — run: bootstrap.sh git"
fi

if [[ -n "${GITHUB_ACCOUNTS:-}" ]]; then
  for acct in $GITHUB_ACCOUNTS; do
    if [[ -f "$DOTFILES_DIR/.local/.gitconfig-${acct}" ]]; then
      ok ".gitconfig-${acct} exists"
    else
      warn ".gitconfig-${acct} missing — run: bootstrap.sh git"
    fi
  done
else
  warn "No GitHub accounts in machine.sh — run: bootstrap.sh to configure"
fi

# ── SSH ───────────────────────────────────────────────────────────────────────
section "SSH"

if [[ -n "${GITHUB_ACCOUNTS:-}" ]]; then
  for acct in $GITHUB_ACCOUNTS; do
    KEY="$HOME/.ssh/id_ed25519_${acct}"
    if [[ -f "$KEY" ]]; then
      ok "SSH key exists: ~/.ssh/id_ed25519_${acct}"
      if ssh-add -l 2>/dev/null | grep -q "id_ed25519_${acct}"; then
        ok "SSH key loaded in agent (@${acct})"
      else
        warn "SSH key not in agent — run: ssh-add --apple-use-keychain ~/.ssh/id_ed25519_${acct}"
      fi
      if ssh -T "git@github-${acct}" 2>&1 | grep -q "successfully authenticated"; then
        ok "GitHub SSH working: @${acct}"
      else
        warn "GitHub SSH not verified (@${acct}) — run: ssh -T git@github-${acct}"
      fi
    else
      fail "No SSH key for @${acct} — run: bootstrap.sh ssh"
    fi
  done
else
  warn "No GitHub accounts in machine.sh — run: bootstrap.sh to configure"
fi

mkdir -p "$HOME/.ssh/control"
ok "SSH control socket directory: ~/.ssh/control"

# ── bin/ Scripts ──────────────────────────────────────────────────────────────
section "Custom Scripts (bin/)"

if echo "$PATH" | tr ':' '\n' | grep -q "$DOTFILES_DIR/bin"; then
  ok "bin/ is on PATH"
else
  fail "bin/ not on PATH — check .zshrc is symlinked and reload shell"
fi

SCRIPTS=(
  findport killport flushdns clearcache diskcheck sysinfo purge setup-captures
  cppath mkcd batchrename imgresize convert2jpg zipdir trash
  gnuke gpr grepo ghealthcheck gclean
)
MISSING_SCRIPTS=()
for s in "${SCRIPTS[@]}"; do
  [[ -x "$DOTFILES_DIR/bin/$s" ]] || MISSING_SCRIPTS+=("$s")
done

if [[ ${#MISSING_SCRIPTS[@]} -eq 0 ]]; then
  ok "All ${#SCRIPTS[@]} scripts present and executable"
else
  fail "Missing or non-executable scripts: ${MISSING_SCRIPTS[*]}"
fi

# ── Sync ──────────────────────────────────────────────────────────────────────
section "Git Sync"

if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree &>/dev/null; then
  REMOTE=$(git -C "$DOTFILES_DIR" remote get-url origin 2>/dev/null || echo "none")
  ok "Git repo initialised — remote: $REMOTE"

  git -C "$DOTFILES_DIR" fetch --quiet origin 2>/dev/null || true
  BEHIND=$(git -C "$DOTFILES_DIR" rev-list HEAD..origin/main --count 2>/dev/null || echo 0)
  AHEAD=$(git -C "$DOTFILES_DIR"  rev-list origin/main..HEAD --count 2>/dev/null || echo 0)

  [[ "$BEHIND" -eq 0 ]] && ok "Up to date with origin/main" \
    || warn "$BEHIND commit(s) behind — run: dsync pull"
  [[ "$AHEAD" -eq 0 ]]  && ok "Nothing waiting to push" \
    || warn "$AHEAD commit(s) ahead  — run: dsync"
else
  fail "Dotfiles repo has no git remote — push to GitHub first"
fi

# Check LaunchAgent
if launchctl list 2>/dev/null | grep -q "com.dotfiles.sync"; then
  ok "Auto-sync LaunchAgent is running"
else
  warn "Auto-sync LaunchAgent not active — run bootstrap.sh or load it manually"
fi

# ── Screenshots & Recordings ──────────────────────────────────────────────────
section "Screenshots & Recordings"

SCREENSHOT_LOC=$(defaults read com.apple.screencapture location 2>/dev/null || echo "")
EXPECTED_LOC="$HOME/Downloads/Screenshots"

if [[ "$SCREENSHOT_LOC" == "$EXPECTED_LOC" ]]; then
  ok "Screenshot location: ~/Downloads/Screenshots"
else
  warn "Screenshots saving to: ${SCREENSHOT_LOC:-default Desktop} — run: setup-captures"
fi

[[ -d "$HOME/Downloads/Screenshots" ]]     && ok "Folder exists: ~/Downloads/Screenshots"     || warn "Folder missing — run: setup-captures"
[[ -d "$HOME/Downloads/Screen Recordings" ]] && ok "Folder exists: ~/Downloads/Screen Recordings" || warn "Folder missing — run: setup-captures"

if launchctl list 2>/dev/null | grep -q "com.captures.watcher"; then
  ok "Desktop capture watcher is running"
else
  warn "Desktop capture watcher not active — run: setup-captures"
fi

# ── VS Code ───────────────────────────────────────────────────────────────────
section "VS Code"

if command -v code &>/dev/null; then
  ok "VS Code CLI (code) available"
else
  warn "'code' command not found — open VS Code → Cmd+Shift+P → 'Shell Command: Install code'"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo -e "\n${BOLD}────────────────────────────────────────────────${RESET}"
echo -e "  ${GREEN}✓ Passed:  $PASS${RESET}   ${YELLOW}⚠ Warnings: $WARN${RESET}   ${RED}✗ Failed: $FAIL${RESET}"
echo -e "${BOLD}────────────────────────────────────────────────${RESET}\n"

if [[ "$FAIL" -gt 0 ]]; then
  echo -e "${RED}Some things need fixing. Address the ✗ items above.${RESET}\n"
  exit 1
elif [[ "$WARN" -gt 0 ]]; then
  echo -e "${YELLOW}Setup mostly complete. Review the ⚠ warnings above.${RESET}\n"
  exit 0
else
  echo -e "${GREEN}Everything looks great. You're fully set up.${RESET}\n"
  exit 0
fi
