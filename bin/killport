#!/usr/bin/env bash
# =============================================================================
# killport — Show what's on a port and kill it
# Usage:
#   killport 3000          # shows process info, asks to confirm, then kills
#   killport 3000 --force  # kills immediately without asking
# =============================================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'

[[ "${1:-}" == "--help" || -z "${1:-}" ]] && {
  echo "Usage: killport <port> [--force]"
  echo ""
  echo "  killport 3000          show what's running and ask before killing"
  echo "  killport 3000 --force  kill immediately without asking"
  exit 0
}

PORT="$1"
FORCE="${2:-}"

# ── Find what's on the port ───────────────────────────────────────────────────
INFO=$(lsof -iTCP:"$PORT" -sTCP:LISTEN -n -P 2>/dev/null || true)

if [[ -z "$INFO" ]]; then
  echo -e "${YELLOW}Nothing is running on port $PORT${RESET}"
  exit 0
fi

# ── Show process info ─────────────────────────────────────────────────────────
echo -e "\n${BOLD}Port $PORT is in use:${RESET}\n"
printf "  %-12s %-8s %-20s %s\n" "PROCESS" "PID" "USER" "COMMAND"
printf "  %-12s %-8s %-20s %s\n" "-------" "---" "----" "-------"

while IFS= read -r line; do
  [[ "$line" == COMMAND* ]] && continue
  PROC=$(echo "$line" | awk '{print $1}')
  PID=$(echo  "$line" | awk '{print $2}')
  USER=$(echo "$line" | awk '{print $3}')
  CMD=$(ps -p "$PID" -o command= 2>/dev/null | cut -c1-60 || echo "—")
  printf "  ${BLUE}%-12s${RESET} %-8s %-20s %s\n" "$PROC" "$PID" "$USER" "$CMD"
done <<< "$INFO"

echo ""

# ── Kill ──────────────────────────────────────────────────────────────────────
PIDS=$(echo "$INFO" | awk 'NR>1 {print $2}' | sort -u)

if [[ "$FORCE" != "--force" ]]; then
  read -rp "Kill process(es) on port $PORT? [y/N]: " CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || { echo "Cancelled."; exit 0; }
fi

echo "$PIDS" | xargs kill -9 2>/dev/null
echo -e "${GREEN}✓ Killed port $PORT${RESET}"
