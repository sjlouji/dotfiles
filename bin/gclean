#!/usr/bin/env bash
# gclean — Clean up a git repo: remove .DS_Store, prune remote refs, fix line endings
set -euo pipefail
[[ "${1:-}" == "--help" ]] && { echo "Usage: gclean [--dry-run]"; echo "Removes .DS_Store files, prunes remote refs, and tidies up the repo."; exit 0; }
DRY="${1:-}"
git rev-parse --is-inside-work-tree &>/dev/null || { echo "✗ Not a git repo"; exit 1; }
echo "▶ Cleaning repo: $(basename "$(git rev-parse --show-toplevel)")"
if [[ "$DRY" != "--dry-run" ]]; then
  find . -name ".DS_Store" -not -path "./.git/*" -delete && echo "  ✓ Removed .DS_Store files"
  git fetch --prune --quiet && echo "  ✓ Pruned stale remote refs"
  git gc --auto --quiet && echo "  ✓ Git GC complete"
else
  echo "  (dry run)"
  find . -name ".DS_Store" -not -path "./.git/*" | while read -r f; do echo "  Would remove: $f"; done
fi
echo "✓ Done"
