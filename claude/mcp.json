{
  "mcpServers": {

    // ── Version Control ──────────────────────────────────────────────────────
    // Token: gh auth token  OR  store in Apple Keychain as GITHUB_TOKEN
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    // ── Local Files ──────────────────────────────────────────────────────────
    // Gives Claude access to read/write files in your project folders
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/${USER}/personal",
        "/Users/${USER}/work",
        "/Users/${USER}/projects"
      ]
    },

    // ── Design ───────────────────────────────────────────────────────────────
    // Figma — inspect components, read design tokens, extract assets
    // Token: Figma → Settings → Personal access tokens
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--figma-api-key=${FIGMA_API_KEY}", "--stdio"]
    },

    // ── Communication ─────────────────────────────────────────────────────────
    // Slack — read channels, search messages, post updates
    // Token: https://api.slack.com/apps → Bot Token (xoxb-...)
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },

    // ── Docs & Knowledge ─────────────────────────────────────────────────────
    // Notion — read/write pages, query databases
    // Token: https://www.notion.so/my-integrations → create integration
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_TOKEN}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    },

    // ── Memory ───────────────────────────────────────────────────────────────
    // Persists context across Claude sessions (entities, relationships, facts)
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }

  }
}
