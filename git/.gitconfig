# =============================================================================
# .gitconfig — Global git config
# Machine-specific identity is injected via .local/machine.sh at shell start,
# then picked up by the [includeIf] blocks below.
# =============================================================================

[core]
  editor        = code --wait
  pager         = delta
  excludesFile  = ~/.dotfiles/git/.gitignore_global
  autocrlf      = input
  whitespace    = trailing-space,space-before-tab

[commit]
  template      = ~/.dotfiles/git/.gitmessage

[init]
  defaultBranch = main
  templateDir   = ~/.git_template

[pull]
  rebase = true

[push]
  default       = current
  autoSetupRemote = true

[rebase]
  autostash  = true
  autosquash = true

[fetch]
  prune = true

[merge]
  conflictstyle = zdiff3

[diff]
  algorithm     = histogram
  colorMoved    = zebra

# ── Delta (diff pager) ────────────────────────────────────────────────────────
[interactive]
  diffFilter    = delta --color-only

[delta]
  navigate      = true
  light         = false
  side-by-side  = true
  line-numbers  = true
  syntax-theme  = Dracula

# ── Aliases ───────────────────────────────────────────────────────────────────
[alias]
  # Status / info
  st            = status -sb
  aliases       = config --get-regexp alias
  whoami        = "!echo \"$(git config user.name) <$(git config user.email)>\""
  root          = rev-parse --show-toplevel
  branches      = for-each-ref --sort=-committerdate --format="%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)" refs/remotes
  recent        = branch --sort=-committerdate --format='%(refname:short) — %(committerdate:relative)'
  # Log
  lg            = log --oneline --decorate --graph
  lga           = log --oneline --decorate --graph --all
  # Staging
  aa            = add --all
  ap            = add --patch
  # Commit
  ci            = commit -v
  wip           = "!git add -A && git commit -m 'wip: $(date +%Y-%m-%d)'"
  # Checkout
  co            = checkout
  # Push
  pf            = push --force-with-lease
  # Undo / restore
  undo          = reset HEAD~1 --soft
  unstage       = restore --staged
  discard       = restore
  # Cleanup
  branch-clean  = "!git branch --merged main | grep -v 'main\\|\\*' | xargs git branch -d"

# ── URL shortcuts ─────────────────────────────────────────────────────────────
[url "git@github.com:"]
  insteadOf = https://github.com/

# ── Credential helpers ────────────────────────────────────────────────────────
[credential]
  helper = osxkeychain

# ── Identity: per-directory overrides ────────────────────────────────────────
# These files live in .local/ (gitignored) — created by bootstrap.sh.
#
# ~/.dotfiles/.local/.gitconfig-work should contain:
# [user]
#   name  = Your Name
#   email = you@work.com
#
# ~/.dotfiles/.local/.gitconfig-personal should contain:
# [user]
#   name  = Your Name
#   email = you@personal.com
#
[includeIf "gitdir:~/work/"]
  path = ~/.dotfiles/.local/.gitconfig-work

[includeIf "gitdir:~/personal/"]
  path = ~/.dotfiles/.local/.gitconfig-personal

[includeIf "gitdir:~/projects/"]
  path = ~/.dotfiles/.local/.gitconfig-personal

# ── Colors ───────────────────────────────────────────────────────────────────
[color]
  ui = auto

[color "branch"]
  current = yellow reverse
  local   = yellow
  remote  = green

[color "diff"]
  meta       = yellow bold
  frag       = magenta bold
  old        = red bold
  new        = green bold
  whitespace = red reverse

# ── Machine-local overrides (gitignored) ─────────────────────────────────────
# Drop any machine-specific config in ~/.dotfiles/.local/.gitconfig.local
[include]
  path = ~/.dotfiles/.local/.gitconfig.local
