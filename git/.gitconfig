# =============================================================================
# .gitconfig — Global git config
# Identity routing is fully dynamic — configured by bootstrap.sh per account.
# See .local/.gitconfig-accounts for the generated includeIf rules.
# =============================================================================

[core]
  editor        = code --wait
  pager         = delta
  excludesFile  = ~/.dotfiles/git/.gitignore_global
  autocrlf      = input
  whitespace    = trailing-space,space-before-tab

[commit]
  template      = ~/.dotfiles/git/.gitmessage

[init]
  defaultBranch = main
  templateDir   = ~/.git_template

[pull]
  rebase = true

[push]
  default       = current
  autoSetupRemote = true

[rebase]
  autostash  = true
  autosquash = true

[fetch]
  prune = true

[merge]
  conflictstyle = zdiff3

[diff]
  algorithm     = histogram
  colorMoved    = zebra

# ── Delta (diff pager) ────────────────────────────────────────────────────────
[interactive]
  diffFilter    = delta --color-only

[delta]
  navigate      = true
  light         = false
  side-by-side  = true
  line-numbers  = true
  syntax-theme  = Dracula

# ── Aliases ───────────────────────────────────────────────────────────────────
[alias]
  # Status / info
  st            = status -sb
  aliases       = config --get-regexp alias
  whoami        = "!echo \"$(git config user.name) <$(git config user.email)>\""
  root          = rev-parse --show-toplevel
  branches      = for-each-ref --sort=-committerdate --format="%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)" refs/remotes
  recent        = branch --sort=-committerdate --format='%(refname:short) — %(committerdate:relative)'
  # Log
  lg            = log --oneline --decorate --graph
  lga           = log --oneline --decorate --graph --all
  # Staging
  aa            = add --all
  ap            = add --patch
  # Commit
  ci            = commit -v
  wip           = "!git add -A && git commit -m 'wip: $(date +%Y-%m-%d)'"
  # Checkout
  co            = checkout
  # Push
  pf            = push --force-with-lease
  # Undo / restore
  undo          = reset HEAD~1 --soft
  unstage       = restore --staged
  discard       = restore
  # Cleanup
  branch-clean  = "!git branch --merged main | grep -v 'main\\|\\*' | xargs git branch -d"

# ── URL shortcuts ─────────────────────────────────────────────────────────────
[url "git@github.com:"]
  insteadOf = https://github.com/

# ── Credential helpers ────────────────────────────────────────────────────────
[credential]
  helper = osxkeychain

# ── Identity: per-directory overrides ────────────────────────────────────────
# Identity routing is generated by bootstrap.sh and lives in .local/ (gitignored).
# Each GitHub account gets its own .gitconfig-<username> and a folder mapping.
#
# .local/.gitconfig-accounts contains all the [includeIf] blocks, e.g.:
#   [includeIf "gitdir:~/personal/"]
#     path = ~/.dotfiles/.local/.gitconfig-sjlouji
#   [includeIf "gitdir:~/work/"]
#     path = ~/.dotfiles/.local/.gitconfig-jlouji
#
# To add or change accounts, run bootstrap.sh or edit .local/.gitconfig-accounts.
# Run 'git whoami' in any repo to confirm which identity is active.

# ── Colors ───────────────────────────────────────────────────────────────────
[color]
  ui = auto

[color "branch"]
  current = yellow reverse
  local   = yellow
  remote  = green

[color "diff"]
  meta       = yellow bold
  frag       = magenta bold
  old        = red bold
  new        = green bold
  whitespace = red reverse

# ── Machine-local overrides + account identity routing ───────────────────────
# .gitconfig.local is machine-specific (gitignored) and includes:
#   - .gitconfig-accounts (all [includeIf] identity routing)
#   - any manual machine-specific overrides
[include]
  path = ~/.dotfiles/.local/.gitconfig.local
